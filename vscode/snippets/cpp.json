      "        if (r1 >= r2 || c1 >= c2) return;",
      "",
      "        data[r1][c1] += v;",
      "        data[r1][c2] -= v;",
      "        data[r2][c1] -= v;",
      "        data[r2][c2] += v;",
      "    }",
      "",
      "    vector<vector<T>>& build () {",
      "        if (is_build) return data;",
      "        for(ll i = 0; i <= H; i++) {",
      "            for (ll j = 1; j <= W; j++) data[i][j] += data[i][j - 1];",
      "        }",
      "        for (ll j = 0; j <= W; j++) {",
      "            for (ll i = 1; i <= H; i++) data[i][j] += data[i - 1][j];",
      "        }",
      "        return data;",
      "    }",
      "",
      "    long long get(ll r, ll c) {",
      "        return data[r][c];",
      "    }",
      "};"
    ]
  },
