      "struct TrieNode {",
      "    vector<long long> next;",
      "    long long accept;",
      "    long long count;",
      "",
      "    TrieNode() {",
      "        next.assign(26, -1);",
      "        accept = 0;",
      "        count = 0;",
      "    }",
      "};",
      "",
      "struct Trie {",
      "    vector<TrieNode> nodes;",
      "",
      "    Trie() {",
      "        nodes.push_back(TrieNode());",
      "    }",
      "",
      "    long long chartoll(char c) {",
      "        return c - 'a';",
      "    }",
      "",
      "    void insert(const string& word) {",
      "        long long cur = 0;",
      "        for (char c : word) {",
      "            long long idx = chartoll(c);",
      "            ",
      "            if (nodes[cur].next[idx] == -1) {",
      "                nodes[cur].next[idx] = nodes.size();",
      "                nodes.push_back(TrieNode());",
      "            }",
      "",
      "            cur = nodes[cur].next[idx];",
      "            nodes[cur].count++;",
      "        }",
      "        nodes[cur].accept++;",
      "    }",
      "",
      "    bool search(const string& word) {",
      "        long long cur = 0;",
      "        for (char c : word) {",
      "            long long idx = chartoll(c);",
      "            if (nodes[cur].next[idx] == -1) {",
      "                return false;",
      "            }",
      "            cur = nodes[cur].next[idx];",
      "        }",
      "        return nodes[cur].accept > 0;",
      "    }",
      "",
      "    long long count_prefix(const string& prefix) {",
      "        long long cur = 0;",
      "        for (char c : prefix) {",
      "            long long idx = chartoll(c);",
      "            if (nodes[cur].next[idx] == -1) {",
      "                return 0;",
      "            }",
      "            cur = nodes[cur].next[idx];",
      "        }",
      "        return nodes[cur].count;",
      "    }",
      "",
      "    long long get_max_lcp(const string& word) {",
      "        long long cur = 0;",
      "        long long res = 0;",
      "        for (char c : word) {",
      "            long long idx = chartoll(c);",
      "            cur = nodes[cur].next[idx];",
      "",
      "            if (nodes[cur].count > 1) {",
      "                res++;",
      "            }",
      "            else {",
      "                break;",
      "            }",
      "        }",
      "        return res;",
      "    }",
      "};"
    ]
