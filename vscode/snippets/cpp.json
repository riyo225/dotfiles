  "swagqueue": {
    "prefix": "swagqueue\r",
    "body": [
      "\r",
      "template <class Monoid>\r",
      "struct SwagQueue {\r",
      "    using T = typename Monoid::Type;\r",
      "    // front: 削除, back: 追加\r",
      "    // first: 値, second: 演算結果\r",
      "    stack<pair<T, T>> front, back;\r",
      "\r",
      "    SwagQueue() {}\r",
      "\r",
      "    ll size() const { return ll(front.size() + back.size()); }\r",
      "    bool empty() const { return front.empty() && back.empty(); }\r",
      "\r",
      "    void push(T val) {\r",
      "        if (back.empty()) {\r",
      "            back.push({val, Monoid::op(Monoid::e(), val)});\r",
      "        }\r",
      "        else {\r",
      "            back.push({val, Monoid::op(back.top().second, val)});\r",
      "        }\r",
      "    }\r",
      "\r",
      "    void pop() {\r",
      "        if (front.empty()) {\r",
      "            while (!back.empty()) {\r",
      "                T val = back.top().first;\r",
      "                back.pop();\r",
      "                T aggregate = val;\r",
      "                if (!front.empty()) {\r",
      "                    aggregate = Monoid::op(val, front.top().second);\r",
      "                }\r",
      "                front.push({val, aggregate});\r",
      "            }\r",
      "        }\r",
      "        if (!front.empty()) front.pop();\r",
      "    }\r",
      "\r",
      "    T fold () {\r",
      "        if (empty()) return Monoid::e();\r",
      "        if (front.empty()) return back.top().second;\r",
      "        if (back.empty()) return front.top().second;\r",
      "        return Monoid::op(front.top().second, back.top().second);\r",
      "    }\r",
      "};"
    ]
  },
